# Copy this file to .env and replace values with your EmailJS project settings.
# The contact form sends messages through EmailJS to the mailbox configured in your template.

VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# Optional: used as fallback recipient text and hidden form field.
VITE_CONTACT_RECEIVER_EMAIL=opfluxsolution@gmail.com
